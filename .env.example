# LANSMARK 환경변수 (이 파일을 .env로 복사 후 채우기)

# 데이터 모드: auto(기본·키 있는 통합만 live, 나머지 mock 폴백) | mock(전부 데모) | live(전부 실연동·키없으면 throw)
LANSMARK_DATA_MODE=auto

# VWorld 운영키 (지오코딩 + 위성타일 + 필지 WFS + DEM)
#  활용 API: 지오코더 / WMTS·TMS / WMS·WFS / 2D데이터 / 3D Data
VWORLD_API_KEY=

# 기상청 API허브 (ASOS 일자료/평년값)
KMA_API_KEY=

# KAMIS(aT) 일별 품목별 도·소매가격
KAMIS_API_KEY=
KAMIS_API_ID=

# ── 외부연동 준비(HUMAN GATE) — 발급/신청 절차는 HUMAN_GATE.md 참조 ──
# 키 꽂으면 src/lansmark/integrations/* seam이 인식(현황=listIntegrations). 실응답 파서는 키 확보 후 슬라이스 승격 시 작성(추측 금지).
# 기상특보: 별도 키 불필요 — 위 KMA_API_KEY 그대로 + apihub에서 '특보 API 활용신청' 클릭(자동승인, 403 해소)
# NCPMS(농진청) 병해충 예찰·발생 — ncpms.rda.go.kr OpenAPI apiKey (또는 data.go.kr serviceKey 택1)
NCPMS_API_KEY=
# 농사로(농진청) 국내 작물 재배정보(재배시기·관수·품종) — nongsaro.go.kr OpenAPI 신청(휴대폰 인증). 국내 작물 전용
NONGSARO_API_KEY=
# 식물 재배정보(외래작물 전용) — Perenual(우선·무료 100/일, perenual.com/user/developer) · Trefle(폴백·불안정). 국내는 농사로 사용
PERENUAL_API_KEY=
TREFLE_TOKEN=
# 공공데이터포털 농업 지원금(보조금24 등) — data.go.kr serviceKey (디코딩 키 권장)
DATA_GO_KR_SERVICE_KEY=
# 브라우저 푸시(VAPID) — 외부 발급 없음·자체 생성(npx web-push generate-vapid-keys). 개인키는 비밀
LANSMARK_VAPID_PUBLIC_KEY=
LANSMARK_VAPID_PRIVATE_KEY=
LANSMARK_VAPID_SUBJECT=mailto:ops@example.com
# 모니터링 스케줄러 — 외부 키 불필요. 데이터 seam 승격 후 1로 켜면 주기 점검 가동(기본 off)
LANSMARK_MONITOR_CRON=

# 결제(PG) — 일반결제(승인+웹훅)
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
PG_WEBHOOK_SECRET=
# 유료 권한 토큰 서명 시크릿(서버 전용 · 운영은 강한 랜덤값 필수 · openssl rand -hex 32)
LANSMARK_ENTITLEMENT_SECRET=
# 계정 식별자 해시 시크릿(전화/이메일 keyed-hash 전용 · 미설정 시 ENTITLEMENT_SECRET 폴백). 시크릿 회전 분리 원하면 별도 설정
LANSMARK_ACCOUNT_SECRET=
# 앱 외부 절대 URL(이메일 매직링크 등) — 운영 필수(예: https://lensmark.kr). dev는 http://localhost:PORT 자동
LANSMARK_APP_ORIGIN=
# 정밀분석 단가(원) · 결제 게이트(true=결제 강제, 기본 on)
LANSMARK_SIM_PRICE_KRW=4900
LANSMARK_REQUIRE_ENTITLEMENT=true
# 운영 콘솔(/ops·/api/ops/stats) 관리자 토큰 (미설정=개발 오픈, 운영 필수)
LANSMARK_ADMIN_TOKEN=

# ── 보안 ──
# 운영 표시(production이면 fail-closed: 시크릿/CORS*/오픈콘솔이면 부팅 차단)
NODE_ENV=
# 운영 fail-closed 우회 플래그(비권장 · 각각 1로 허용)
LANSMARK_ALLOW_DEFAULT_SECRET=
LANSMARK_ALLOW_OPEN_CORS=
LANSMARK_ALLOW_OPEN_CONSOLE=
# CORS 허용 출처: 비움/*(전체) 또는 "https://app.example.com,https://b.example.com"
LANSMARK_CORS_ORIGIN=*
# 신뢰 프록시 홉 수: 0=직노출(X-Forwarded-For 무시·소켓IP). nginx/CF 뒤면 체인 길이에 맞춰 1+
LANSMARK_TRUST_PROXY_HOPS=0
# 레이트리밋(요청/분): 전체 /api/*, 민감 라우트(결제·시뮬·피드백·웹훅·지오조회)
LANSMARK_RATE_GLOBAL=240
LANSMARK_RATE_SENSITIVE=30
# 유료권한 토큰: 수명(시간, 기본 720=30일) · 토큰당 정밀시뮬 허용 횟수(소진형)
LANSMARK_ENTITLEMENT_TTL_HOURS=720
LANSMARK_ENTITLEMENT_QUOTA=50
# 외부 API fetch 타임아웃(ms)
LANSMARK_FETCH_TIMEOUT_MS=7000

# ── 영속성 ──
# 상태(플라이휠·웹훅멱등·토큰소진/실효) 저장: file(재시작 보존·단일인스턴스 기본) | memory(휘발)
#  다중 인스턴스/고throughput은 같은 인터페이스로 DB 어댑터 추가(src/lansmark/db/stores.ts)
LANSMARK_STORE=file
# file 모드 데이터 디렉터리(기본 ./.data · Cloud Run은 쓰기가능 /tmp 권장)
LANSMARK_DATA_DIR=
# at-rest 암호화 키(hex 64자=32바이트 · openssl rand -hex 32) — 설정 시 file 스토어를 AES-256-GCM 암호화. ⚠ 분실=복구불가(백업 필수)
LANSMARK_DATA_KEY=

# 서버 포트
PORT=8787
