{
  "name": "lansmark-simulator",
  "version": "0.78.5",
  "private": true,
  "type": "commonjs",
  "description": "LANSMARK 작물·수확·소득 시뮬레이터 (drop-in module + standalone harness)",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "start": "tsx server/devServer.ts",
    "demo": "tsx scripts/mockRun.ts",
    "dev": "tsx server/devServer.ts",
    "capture": "tsx scripts/captureLiveSamples.ts",
    "arch": "tsx scripts/archCheck.ts",
    "arch:render": "tsx scripts/archRender.ts",
    "size": "tsx scripts/sizeGuard.ts",
    "rda:build": "tsx scripts/buildRdaReal.ts",
    "ops:watch": "tsx scripts/opsWatch.ts",
    "deploy": "bash scripts/deploy.sh",
    "load": "tsx scripts/loadTest.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
